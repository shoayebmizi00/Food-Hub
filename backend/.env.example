# ==========================
# Application
# ==========================
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ==========================
# Database
# ==========================
DATABASE_URL=
# Supabase direct connection format:
# postgresql://postgres:[YOUR-PASSWORD]@db.wzyfbldftmdtkukevmxy.supabase.co:5432/postgres

# ==========================
# Authentication
# ==========================
JWT_SECRET=
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=30d

# ==========================
# Frontend and CORS
# ==========================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ==========================
# Cookies
# ==========================
COOKIE_SECRET=

# ==========================
# Local verification and seeding
# ==========================
DEV_OTP=123456
SEED_USER_PASSWORD=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=

# ==========================
# Email
# ==========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ==========================
# Cloudinary
# ==========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================
# Stripe
# ==========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ==========================
# SSLCommerz
# ==========================
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_LIVE=false

# ==========================
# bKash
# ==========================
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=

# ==========================
# Nagad
