NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://foodcorner:foodcorner@localhost:5432/foodcorner?schema=public

# Supabase PostgreSQL (production) — use Session pooler connection string from Supabase dashboard
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins for CORS
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://your-frontend-domain.com,http://localhost:5173

DEV_OTP=123456

# Payment gateways (backend only — never expose in frontend)
STRIPE_SECRET_KEY=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
