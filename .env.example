# Root variables are used by docker-compose.yml for local PostgreSQL.
POSTGRES_USER=foodcorner
POSTGRES_PASSWORD=
POSTGRES_DB=foodcorner

# App runtime env files live with each app:
# - backend/.env.example for the Render Docker API
# - frontend/.env.example for the Vercel Vite frontend
